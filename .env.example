# Generated by `hearth init` — this is a reference copy. Real values live in .env (gitignored).

# local | byo
HEARTH_MODE=local

# Matrix server name (domain part of user IDs, e.g. @alice:hearth.localhost)
HEARTH_SERVER_NAME=hearth.localhost

# Homeserver URL as reachable from the HOST (agents and CLI use this).
# local mode: http://localhost:6167   byo mode: your existing homeserver URL
HEARTH_HOMESERVER_URL=http://localhost:6167

# Shared-secret style registration token for the local Conduit homeserver.
HEARTH_REGISTRATION_TOKEN=change-me

# Host interface to bind. 127.0.0.1 (default) = this machine only.
# Set 0.0.0.0 only if you know what you're exposing (no built-in TLS/auth).
HEARTH_BIND_ADDRESS=127.0.0.1

# Ports
HEARTH_MATRIX_PORT=6167
HEARTH_ELEMENT_PORT=8009
HEARTH_MEMORY_PORT=8010

# Set by the CLI: activates conduit+element containers only in local mode.
COMPOSE_PROFILES=local-homeserver
